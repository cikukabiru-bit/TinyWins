# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Provide a valid PostgreSQL URL to use Postgres database.
# If left blank, the app will fall back to local JSON database storage (local_store.json) in the src/db directory.
DATABASE_URL=

# Authentication Secret
JWT_SECRET=tinywins_secret_grace_growth_rhythm_321

# Tiny Coach AI Settings
# Provide your OpenAI API key for real AI coach suggestions.
# If left blank or if ENABLE_MOCK_COACH is true, the mock coach will generate gentle local suggestions.
OPENAI_API_KEY=
ENABLE_MOCK_COACH=true
